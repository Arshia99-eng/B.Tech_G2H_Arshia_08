
#include <stdio.h>

int main() {
   int a[5], temp=0;
printf("enter the array\n");
   for(int i=0; i<5;i++)
   {
       scanf("%d",&a[i]);
   }
   for(int i=0; i<5;i++)
   {
       for(int j=i;j<5-i;j++)
       {
           if(a[j]>a[j+1])
           temp=a[j];
       }
   }
   printf("largest element is %d\n",temp);
     return 0;
}
