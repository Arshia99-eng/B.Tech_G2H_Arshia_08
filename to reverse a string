// Online C compiler to run C program online
#include <stdio.h>
#include<string.h>
int main() {
    char str[50], rev[50];
    int len,i,j;
    printf("enter a string ");
    fgets(str, sizeof(str),stdin);
    len=strlen(str);
    for(i=len-1,j=0;i>=0;i--,j++)
    {
        rev[j]=str[i];
    }
    rev[j]='\0';
    printf("original: %s\n",str);
    printf("Reversed: %s\n",rev);
        return 0;
}
