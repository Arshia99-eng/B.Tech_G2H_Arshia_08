#include <stdio.h>
#include<math.h>
int main() {
    int a, b, n1,n2,temp , gcd , lcm;
    printf("enter the two numbers\n");
    scanf("%d%d", &n1,&n2);
    a=n1;
    b=n2;
    while(b!=0)
    {
        temp=b;
        b=a%b;
        a=temp;
    }
    gcd=a;
    lcm=(n1*n2)/gcd;
