
#include <stdio.h>

int main() {
   int a[5], e=0, o=0;
printf("enter the array\n");
   for(int i=0; i<5;i++)
   {
       scanf("%d",&a[i]);
   }
   for(int i=0; i<5;i++)
   {
       if(a[i]%2==0)
       e++;
       else
       o++;
   }
